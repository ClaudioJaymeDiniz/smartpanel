{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "scheme": "mobile",
    "platforms": ["ios", "android", "web"],

    "web": {
      "bundler": "metro",
      "output": "static"
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-sqlite"
    ],

    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },

    "orientation": "portrait",
    "userInterfaceStyle": "light",

    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "googleServicesFile": "./google-services.json",
      "package": "sm.app"
    }
  }
}